{
  "name": "notyfai-cli-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "notyfai-cli-workspace",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@notyfai-cli/templates": {
      "resolved": "packages/templates",
      "link": true
    },
    "node_modules/notyfai": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "notyfai",
      "version": "0.1.3",
      "license": "UNLICENSED",
      "bin": {
        "notyfai": "bin/notyfai.mjs",
        "notyfai-cli": "bin/notyfai.mjs"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/templates": {
      "name": "@notyfai-cli/templates",
      "version": "0.1.0",
      "license": "UNLICENSED"
    }
  }
}
